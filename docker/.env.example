# Copy to .env and fill in before: docker compose -f docker-compose.prod.yml --env-file .env up --build

# Public URLs (used for CORS and frontend build)
PUBLIC_API_URL=http://localhost:8080
PUBLIC_FRONTEND_URL=http://localhost:3000

# Postgres
POSTGRES_DB=qualitywatch
POSTGRES_USER=qualitywatch
POSTGRES_PASSWORD=change-me-postgres

# RabbitMQ
RABBITMQ_USER=qualitywatch
RABBITMQ_PASSWORD=change-me-rabbitmq

# Backend secrets (required in prod profile)
QUALITYWATCH_API_KEY=change-me-upload-key
QUALITYWATCH_DASHBOARD_USER=demo
QUALITYWATCH_DASHBOARD_PASSWORD=change-me-dashboard

# Optional: Spring profile (prod for public deploy)
SPRING_PROFILES_ACTIVE=prod
